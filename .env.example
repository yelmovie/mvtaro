# ============================================================
# 마음코칭 카드 - 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# ------ Supabase (필수) ------
# Supabase 대시보드 → Settings → API 에서 확인
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...YOUR_ANON_KEY...

# ------ 서버 전용 비밀 키 ------
# OPENAI_API_KEY 같은 비밀 키는 브라우저용 VITE_ 환경변수에 넣지 마세요.
# 필요한 경우 서버, Edge Function, 또는 백엔드 비밀 설정에서만 관리하세요.

# ------ PayPal (Sandbox 테스트 시) ------
# https://developer.paypal.com → Apps & Credentials → Sandbox Client ID
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_SANDBOX_CLIENT_ID
# Live 전환 시 위 값을 Live Client ID 로 교체

# ------ Google AdSense (선택) ------
# https://www.google.com/adsense → 계정 → 게시자 ID
VITE_ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# ------ Supabase Edge Function 서버 비밀 키 (Supabase Dashboard 에서 설정, .env 에 넣지 마세요) ------
# Supabase Dashboard → Settings → Edge Functions → Secrets 에서 설정:
#   OPENAI_API_KEY=sk-...
#   PAYPAL_CLIENT_SECRET=YOUR_SECRET
